# Expense Tracker — Monitoring Cron Jobs
# Installed by deploy.yml on each push to main
# To update: modify this file and push to main

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

# Core monitoring + self-healing (every 5 minutes)
*/5 * * * * root /home/ubuntu/expense-tracking-global/script/monitor.sh >> /var/log/monitor_cron.log 2>&1

# SSL certificate expiry check (daily at 3am)
0 3 * * * root /home/ubuntu/expense-tracking-global/script/monitor.sh --ssl-check >> /var/log/ssl_check.log 2>&1

# Disk cleanup — prune old Docker images and truncate large logs (weekly Sunday at 4am)
0 4 * * 0 root /home/ubuntu/expense-tracking-global/script/monitor.sh --cleanup >> /var/log/cleanup.log 2>&1
